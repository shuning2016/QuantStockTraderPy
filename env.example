# Quant AI Stock Trader — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your real keys.
# The app works with any subset — providers without a key show a config error
# instead of crashing, so you only need the ones you actually want to use.
#
# Usage:
#   cp .env.example .env
#   # edit .env with your keys
#   python app.py

# ── Stock data (required for quotes & stock news) ─────────────────
# Free tier available at https://finnhub.io
FINNHUB_KEY=your_finnhub_key_here

# ── Crypto news (optional — only needed for crypto watchlist items) ─
# Free tier available at https://newsapi.org
NEWSAPI_KEY=your_newsapi_key_here

# ── AI providers (set at least one) ──────────────────────────────
# Anthropic Claude — https://console.anthropic.com
CLAUDE_KEY=sk-ant-api03-...

# xAI Grok — https://console.x.ai
GROK_KEY=xai-...

# DeepSeek — https://platform.deepseek.com
DEEPSEEK_KEY=sk-...

# ── Optional ──────────────────────────────────────────────────────
# SerpAPI (not currently used, reserved for future web search)
# SERPAPI_KEY=your_serpapi_key_here

# Flask port (default: 5000)
# PORT=5000
